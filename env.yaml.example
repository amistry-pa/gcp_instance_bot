# Core
GCP_PROJECT_ID: "your-project-id"
INSTANCE_NAME: "my-gpu-instance"
PREFERRED_ZONES: "us-central1-a,us-central1-b,us-central1-c"
MACHINE_TYPE: "a3-highgpu-8g"

# Mode: "fresh" or "snapshot"
# - fresh: create a brand-new VM from a base OS image
# - snapshot: start the existing stopped VM (if any) OR create from SOURCE_SNAPSHOT
MODE: "snapshot"

# Required if MODE=snapshot
SOURCE_SNAPSHOT: "my-snapshot-name"

# Optional (defaults shown)
BOOT_DISK_SIZE_GB: "200"
BOOT_DISK_TYPE: "pd-ssd"
BOOT_IMAGE_PROJECT: "debian-cloud"   # only used when MODE=fresh
BOOT_IMAGE_FAMILY: "debian-12"       # only used when MODE=fresh

# Email notifications (Gmail SMTP)
GMAIL_ADDRESS: "sender@gmail.com"
GMAIL_APP_PASSWORD: "xxxx xxxx xxxx xxxx"
NOTIFICATION_EMAIL_TO: "you@example.com,teammate@example.com"

# Auto-pause scheduler on success (leave SCHEDULER_JOB_NAME empty to disable)
SCHEDULER_REGION: "us-central1"
SCHEDULER_JOB_NAME: "gpu-retry-scheduler"
